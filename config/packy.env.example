# Copy this file to config/packy.env and fill in your real key.
# config/packy.env is ignored by git.

PACKY_API_KEY="sk-your-packy-api-key"
PACKY_API_BASE="https://www.packyapi.com/v1"

AUTO_SUBTITLE_ATR_PROVIDER="packy"
AUTO_SUBTITLE_ATR_MODEL="gpt-5.4-mini"
AUTO_SUBTITLE_ATR_MAX_TOKENS="8192"
AUTO_SUBTITLE_ATR_CHUNK_SIZE="10"
AUTO_SUBTITLE_ATR_CONCURRENCY="8"

# Keep this enabled by default. If your local Python certificate store cannot
# validate PackyAPI but curl works, you can temporarily set this to 0.
PACKY_API_SSL_VERIFY="1"
